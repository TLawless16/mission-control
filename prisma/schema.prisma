  settings       Json?            @default("{}")
  created_at     DateTime         @default(now()) @db.Timestamptz(6)
  updated_at     DateTime         @default(now()) @db.Timestamptz(6)
  audit_log      audit_log[]
  changelog      changelog[]
  clients        clients[]
  content_items  content_items[]
  credit_budgets credit_budgets[]
  credit_usage   credit_usage[]
  documents      documents[]
  ideas          ideas[]
  intel          intel[]
  notes          notes[]
