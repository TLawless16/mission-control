generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model agents {
  id           String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name         String         @unique @db.VarChar(255)
  role         String?        @db.VarChar(255)
  department   String?        @db.VarChar(100)
  description  String?
  model        String?        @db.VarChar(100)
  capabilities Json?          @default("[]")
  config       Json?          @default("{}")
  active       Boolean        @default(true)
  created_at   DateTime       @default(now()) @db.Timestamptz(6)
  updated_at   DateTime       @default(now()) @db.Timestamptz(6)
  credit_usage credit_usage[]
}

model audit_log {
  id            String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  org_id        String?        @db.Uuid
  user_id       String?        @db.Uuid
  action        String         @db.VarChar(100)
  resource_type String         @db.VarChar(100)
  resource_id   String?        @db.Uuid
  ip_address    String?        @db.Inet
  details       Json?          @default("{}")
  created_at    DateTime       @default(now()) @db.Timestamptz(6)
  organizations organizations? @relation(fields: [org_id], references: [id], onUpdate: NoAction)
  users         users?         @relation(fields: [user_id], references: [id], onUpdate: NoAction)

  @@index([org_id], map: "idx_audit_log_org")
  @@index([user_id], map: "idx_audit_log_user")
}

model changelog {
  id            String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  org_id        String?        @db.Uuid
  action        String         @db.VarChar(100)
  entity_type   String?        @db.VarChar(100)
  entity_id     String?        @db.Uuid
  description   String
  performed_by  String?        @db.Uuid
  agent_name    String?        @db.VarChar(100)
  metadata      Json?          @default("{}")
  created_at    DateTime       @default(now()) @db.Timestamptz(6)
  organizations organizations? @relation(fields: [org_id], references: [id], onUpdate: NoAction)
  users         users?         @relation(fields: [performed_by], references: [id], onUpdate: NoAction)

  @@index([entity_type, entity_id], map: "idx_changelog_entity")
  @@index([org_id], map: "idx_changelog_org")
}

model client_contacts {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  client_id       String   @db.Uuid
  name            String   @db.VarChar(255)
  email           String?  @db.VarChar(255)
  phone           String?  @db.VarChar(50)
  role            String?  @db.VarChar(100)
  primary_contact Boolean  @default(false)
  social_links    Json?    @default("{}")
  notes           String?
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @db.Timestamptz(6)
  clients         clients  @relation(fields: [client_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model clients {
  id              String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  org_id          String            @db.Uuid
  name            String            @db.VarChar(255)
  industry        String?           @db.VarChar(100)
  bio             String?
  brand_voice     String?
  target_audience String?
  notes           String?
  tier            String            @default("starter") @db.VarChar(50)
  active          Boolean           @default(true)
  settings        Json?             @default("{}")
  metadata        Json?             @default("{}")
  created_at      DateTime          @default(now()) @db.Timestamptz(6)
  updated_at      DateTime          @default(now()) @db.Timestamptz(6)
  client_contacts client_contacts[]
  organizations   organizations     @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  content_items   content_items[]
  documents       documents[]
  ideas           ideas[]
  client_notes    notes[]
  projects        projects[]
  social_accounts social_accounts[]
  tasks           tasks[]

  @@index([org_id], map: "idx_clients_org")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model content_items {
  id                                     String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  org_id                                 String        @db.Uuid
  client_id                              String?       @db.Uuid
  title                                  String        @db.VarChar(500)
  body                                   String?
  content_type                           String        @db.VarChar(50)
  status                                 String        @default("idea") @db.VarChar(50)
  platform                               String?       @db.VarChar(50)
  scheduled_for                          DateTime?     @db.Timestamptz(6)
  published_at                           DateTime?     @db.Timestamptz(6)
  published_url                          String?
  media_urls                             Json?         @default("[]")
  hashtags                               Json?         @default("[]")
  performance_metrics                    Json?         @default("{}")
  created_by                             String?       @db.Uuid
  approved_by                            String?       @db.Uuid
  metadata                               Json?         @default("{}")
  created_at                             DateTime      @default(now()) @db.Timestamptz(6)
  updated_at                             DateTime      @default(now()) @db.Timestamptz(6)
  users_content_items_approved_byTousers users?        @relation("content_items_approved_byTousers", fields: [approved_by], references: [id], onUpdate: NoAction)
  clients                                clients?      @relation(fields: [client_id], references: [id], onUpdate: NoAction)
  users_content_items_created_byTousers  users?        @relation("content_items_created_byTousers", fields: [created_by], references: [id], onUpdate: NoAction)
  organizations                          organizations @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([client_id], map: "idx_content_client")
  @@index([org_id], map: "idx_content_org")
  @@index([platform], map: "idx_content_platform")
  @@index([scheduled_for], map: "idx_content_scheduled", where: raw("((status)::text = 'scheduled'::text)"))
  @@index([status], map: "idx_content_status")
}

model credit_budgets {
  id                  String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  org_id              String        @db.Uuid
  month               DateTime      @db.Date
  budget_usd          Decimal       @db.Decimal(10, 2)
  spent_usd           Decimal       @default(0) @db.Decimal(10, 2)
  alert_threshold_pct Int?          @default(80)
  created_at          DateTime      @default(now()) @db.Timestamptz(6)
  organizations       organizations @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([org_id, month])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model credit_usage {
  id               String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  org_id           String        @db.Uuid
  agent_id         String?       @db.Uuid
  model            String        @db.VarChar(100)
  input_tokens     Int           @default(0)
  output_tokens    Int           @default(0)
  cost_usd         Decimal       @default(0) @db.Decimal(10, 6)
  task_description String?
  session_id       String?       @db.VarChar(255)
  created_at       DateTime      @default(now()) @db.Timestamptz(6)
  agents           agents?       @relation(fields: [agent_id], references: [id], onUpdate: NoAction)
  organizations    organizations @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([created_at], map: "idx_credit_usage_date")
  @@index([org_id], map: "idx_credit_usage_org")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model documents {
  id              String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  org_id          String        @db.Uuid
  client_id       String?       @db.Uuid
  title           String        @db.VarChar(500)
  category        String        @default("general") @db.VarChar(100)
  content         String?
  file_path       String?
  file_type       String?       @db.VarChar(50)
  file_size_bytes BigInt?
  tags            Json?         @default("[]")
  created_by      String?       @db.Uuid
  created_at      DateTime      @default(now()) @db.Timestamptz(6)
  updated_at      DateTime      @default(now()) @db.Timestamptz(6)
  clients         clients?      @relation(fields: [client_id], references: [id], onUpdate: NoAction)
  users           users?        @relation(fields: [created_by], references: [id], onUpdate: NoAction)
  organizations   organizations @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([client_id], map: "idx_documents_client")
  @@index([org_id], map: "idx_documents_org")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ideas {
  id            String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
